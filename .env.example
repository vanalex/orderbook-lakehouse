# Copy to .env and adjust as needed:  cp .env.example .env
# Loaded into the environment by the Makefile's Scala targets (option 1:
# the shell sources this file, so example.ListCatalogs reads it via sys.env).
# Values below are the demo-stack defaults.
POLARIS_URL=http://localhost:8181
POLARIS_REALM=default-realm
POLARIS_CLIENT_ID=root
POLARIS_CLIENT_SECRET=s3cr3t
POLARIS_CATALOG=orderbook

# Used by the Spark jobs (example.PolarisSpark) to reach MinIO directly,
# since Polaris doesn't vend scoped S3 credentials in this demo setup.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password
AWS_REGION=us-east-1
